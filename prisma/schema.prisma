datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Event {
  id                         String    @id @map("uid")
  slug                       String?
  canonicalUrl               String?   @map("canonicalurl")
  titleFr                    String?   @map("title_fr")
  descriptionFr              String?   @map("description_fr")
  longDescriptionFr          String?   @map("longdescription_fr")
  conditionsFr               String?   @map("conditions_fr")
  keywordsFr                 Json?     @map("keywords_fr")
  
  image                      String?
  imageCredits               String?   @map("imagecredits")
  thumbnail                  String?
  originalImage              String?   @map("originalimage")
  
  updatedAt                  DateTime? @map("updatedat")
  dateRangeFr                String?   @map("daterange_fr")
  firstDateBegin             DateTime? @map("firstdate_begin")
  firstDateEnd               DateTime? @map("firstdate_end")
  lastDateBegin              DateTime? @map("lastdate_begin")
  lastDateEnd                DateTime? @map("lastdate_end")
  timings                    Json?     
  
  accessibility              String?
  accessibilityLabelFr       String[]  @map("accessibility_label_fr")
  
  attendanceMode             Json?     @map("attendancemode")
  onlineAccessLink           String?   @map("onlineaccesslink")
  status                     Json?     
  ageMin                     Int?      @map("age_min")
  ageMax                     Int?      @map("age_max")
  
  originAgendaTitle          String?   @map("originagenda_title")
  originAgendaUid            String?   @map("originagenda_uid")
  category                   String?
  countryFr                  String?   @map("country_fr")
  
  registration               Json?     
  links                      Json?     
  
  contributorEmail           String?   @map("contributor_email")
  contributorContactNumber   String?   @map("contributor_contactnumber")
  contributorContactName     String?   @map("contributor_contactname")
  contributorContactPosition String?   @map("contributor_contactposition")
  contributorOrganization    String?   @map("contributor_organization")

  locationId                 String?   @map("location_uid")
  location                   Location? @relation(fields: [locationId], references: [id])

  embedding                  Unsupported("vector")?
  isIgnored                  Boolean   @default(false) @map("is_ignored")
  ignoreReason               String?   @map("ignore_reason")

  @@map("events")
}

model Location {
  id            String   @id @map("location_uid")
  coordinates   Json?    @map("location_coordinates")
  name          String?  @map("location_name")
  address       String?  @map("location_address")
  district      String?  @map("location_district")
  insee         String?  @map("location_insee")
  postalCode    String?  @map("location_postalcode")
  city          String?  @map("location_city")
  department    String?  @map("location_department")
  region        String?  @map("location_region")
  countryCode   String?  @map("location_countrycode")
  
  image         String?  @map("location_image")
  imageCredits  String?  @map("location_imagecredits")
  
  phone         String?  @map("location_phone")
  website       String?  @map("location_website")
  links         String?  @map("location_links")
  tags          Json?    @map("location_tags")
  descriptionFr String?  @map("location_description_fr")
  accessFr      String?  @map("location_access_fr")

  events        Event[]

  @@map("locations")
}

model PointOfInterest {
  id              String   @id
  
  osmId           String?  @map("osm_id")
  osmType         String?  @map("osm_type") 
  
  name            String?
  category        String?  
  cuisine         String?  
  siret           String?  @map("ref_siret") 
  
  coordinates     Json?    
  
  street          String?  @map("address_street")
  housenumber     String?  @map("address_housenumber")
  postcode        String?  @map("address_postcode")
  city            String?  @map("address_city")
  
  phone           String?
  website         String?
  facebook        String?
  
  openingHours    String?  @map("opening_hours")
  wheelchair      String?  
  indoorSeating   String?  @map("indoor_seating")
  outdoorSeating  String?  @map("outdoor_seating")
  vegetarian      String?  @map("diet_vegetarian")
  
  description     String?  
  source          String?  
  image           String?  

  summary         String?  
  embedding       Unsupported("vector")?

  rawTags         Json?    @map("raw_tags")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("points_of_interest")
}

// --- NOUVELLE TABLE ---
model OpenAgenda {
  uid         String   @id @map("uid")
  title       String?
  description String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("open_agendas")
}
// 1. On garde ton générateur et ton dossier de sortie personnalisé !
generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

// 2. On met à jour la connexion pour pointer vers tes 2 nouvelles variables Supabase
datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// 3. On ajoute tes tables pour les plateformes et les entreprises
model Platform {
  id        BigInt    @id @default(autoincrement())
  name      String    @unique
  companies Company[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("platforms")
}

model Company {
  id         BigInt   @id @default(autoincrement())
  name       String
  url        String
  platformId BigInt   @map("platform_id")
  platform   Platform @relation(fields: [platformId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("companies")
}